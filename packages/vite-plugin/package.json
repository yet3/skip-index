{
	"name": "@skip-index/vite-plugin",
	"private": false,
	"version": "1.0.0",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"license": "MIT",
	"author": "yet3",
	"description": "A vite plugin that remove the need for `index.ts` barrel files.",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"publish": "bun publish --access public",
		"prepublishOnly": "bun run build"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/bun": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"shared-lib": "workspace:*"
	},
	"peerDependencies": {
		"vite": "*"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yet3/skip-index.git"
	},
	"bugs": {
		"url": "https://github.com/yet3/skip-index/issues"
	},
	"homepage": "https://github.com/yet3/skip-index/tree/main/packages/vite-plugin#readme"
}
