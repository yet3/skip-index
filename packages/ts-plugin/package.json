{
	"name": "@skip-index/ts-plugin",
	"private": false,
	"version": "1.0.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"publish": "bun publish --access public",
		"prepublishOnly": "bun run build"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/bun": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"shared-lib": "workspace:*"
	}
}
