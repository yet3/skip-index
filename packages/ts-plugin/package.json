{
	"name": "@skip-index/ts-plugin",
	"private": false,
	"version": "1.0.2",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"license": "MIT",
	"author": "yet3",
	"description": "A TypeScript plugin that resolves a directory import to a file within that mirrors its name.",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"publish": "bun publish --access public",
		"prepublishOnly": "bun run build"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/bun": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"shared-lib": "workspace:*"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yet3/skip-index.git"
	},
	"bugs": {
		"url": "https://github.com/yet3/skip-index/issues"
	},
	"homepage": "https://github.com/yet3/skip-index/tree/main/packages/ts-plugin#readme"
}


